{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/categories/layout,_N_T_/categories/[slug]/layout,_N_T_/categories/[slug]/page,_N_T_/categories/copywriting"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/categories/$d$slug/__PAGE__",
    "/categories/$d$slug",
    "/categories",
    "/_index",
    "/_head"
  ]
}